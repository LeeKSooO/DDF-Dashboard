# ===========================================
# DDF-ASTGCN Project .gitignore
# ===========================================

# ===========================================
# ⚠️ SECURITY CRITICAL FILES
# ===========================================
# Environment variables (contains DB passwords, API keys)
.env
.env.local
.env.development
.env.test
.env.production

# RAG-specific sensitive data
chroma/
data/documents/

# ⚠️ SENSITIVE DATA: Transportation usage data
data/raw/usages/*.csv
data/raw/POI/
data/processed/*.csv
data/processed/*.npz
data/processed/monthly/*.npz
data/colab_dataset/*.npz

# Keep data structure and scripts, but exclude actual data
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/data_preparation/
!data/etl/
!data/scripts/

# ⚠️ TRAINED MODELS: IP and large files
ai/ddf_model/
ai/torchserve/model-store/
backend/ddf_model/
*.pth
*.pt
*.pkl
*.mar

# ===========================================
# Infrastructure
# ===========================================
infrastructure/restore_streaming.log
infrastructure/database/data/
infrastructure/monitoring/logs/
infrastructure/.DS_Store
infrastructure/database/.DS_Store

# ===========================================
# Kubernetes Secrets
# ===========================================
k8s/**/secret.yaml
k8s/**/secrets.yaml
k8s/**/secret-*.yaml

# ===========================================
# RAG Service
# ===========================================
RAG/.env
RAG/chroma/
RAG/data/documents/*.pdf
RAG/logs/
RAG/.last_install
RAG/etl/__pycache__/
RAG/app/__pycache__/

# ===========================================
# Python (Backend)
# ===========================================
__pycache__/
*.py[cod]
*$py.class

# Root level Python cache
/__pycache__/
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# Virtual environment
venv/
env/
ENV/

# Jupyter Notebook
.ipynb_checkpoints

# Python version management
.python-version

# ===========================================
# Node.js/React (Frontend)
# ===========================================
frontend/node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package manager files
package-lock.json

# ===========================================
# Database
# ===========================================
*.db
*.sqlite
*.sqlite3

# PostgreSQL data volume (contains database files)
# Note: Only ignoring root-level postgres directories, not k8s/postgres
/postgres/
/postgres_backup/

# ===========================================
# Logs
# ===========================================
*.log
logs/
backend/logs/

# ===========================================
# Docker
# ===========================================
docker-compose.override.yml

# ===========================================
# IDE Files
# ===========================================
.vscode/
.idea/
*.swp
*.swo

# ===========================================
# OS Files
# ===========================================
.DS_Store
._*
Thumbs.db
Desktop.ini

# ===========================================
# Temporary Files
# ===========================================
*.tmp
*.temp
temp/
tmp/

# ===========================================
# Test Files
# ===========================================
test/
test_*.py
*_test.py
tests/
scripts/test_*.py


# ===========================================
# Cache
# ===========================================
.cache/
.eslintcache

# ===========================================
# Kubernetes
# ===========================================
# Secret files (should use sealed-secrets or external secret management)
k8s/*/secret.yaml
k8s/**/*secret*.yaml
k8s/**/secrets/

# Helm values with sensitive data
k8s/**/values-local.yaml
k8s/**/values-dev.yaml
k8s/**/values-prod.yaml

# Generated manifests
k8s/**/*.generated.yaml
k8s/**/.rendered/

# Temporary kustomization files
k8s/**/kustomization-tmp.yaml

# ===========================================
# Project-specific exclusions
# ===========================================
# Legacy files and temporary data
regacy/
reports/
shared_files/

# Additional virtual environments
test_env/
venv_*/

# Large data files and sensitive data
data/processed/*.csv
data/processed/*.json
data/processed/*.npz
data/processed/monthly/
data/colab_dataset/
data/raw/sample_data_*.csv

# TorchServe model archives and logs
ai/torchserve/model-store/*.mar
ai/torchserve/logs/

# Application specific logs
backend/logs/*.log

# Config files that might contain sensitive info
*.properties

# ===========================================
# Database Backups
# ===========================================
*.sql
*.dump
*.backup
*_backup.sql
*_dump.sql
database/backups/
backups/

# ===========================================
# Next.js
# ===========================================
frontend/.next/
frontend/out/
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ===========================================
# Infrastructure
# ===========================================
# Terraform
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# AWS credentials
.aws/
aws-credentials

# Kubernetes contexts/configs
.kube/
kubeconfig
*.kubeconfig




# regacy
rag-legacy
legacy

# Reference files (API docs, swagger files, etc.)
frontend/reference/frontend_bak/


data/raw/0715-0731
data/processed/od/
data/OD_process


docs/
scripts/