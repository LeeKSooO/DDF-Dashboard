# ===========================================
# DDF-ASTGCN Project .gitignore
# ===========================================

# ===========================================
# ⚠️ SECURITY CRITICAL FILES
# ===========================================
# Environment variables (contains DB passwords, API keys)
.env
.env.local
.env.development
.env.test
.env.production

# ⚠️ SENSITIVE DATA: Transportation usage data
data/raw/usages/*.csv
data/raw/POI/
data/processed/*.csv
data/processed/*.npz
data/processed/monthly/*.npz
data/colab_dataset/*.npz

# Keep data structure and scripts, but exclude actual data
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/data_preparation/
!data/etl/
!data/scripts/

# ⚠️ TRAINED MODELS: IP and large files
ai/ddf_model/
ai/torchserve/model-store/
backend/ddf_model/
*.pth
*.pt
*.pkl
*.mar

# ===========================================
# Python (Backend)
# ===========================================
__pycache__/
*.py[cod]
*$py.class
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# Virtual environment
venv/
env/
ENV/

# Jupyter Notebook
.ipynb_checkpoints

# Python version management
.python-version

# ===========================================
# Node.js/React (Frontend)
# ===========================================
frontend/node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package manager files
package-lock.json

# ===========================================
# Database
# ===========================================
*.db
*.sqlite
*.sqlite3

# ===========================================
# Logs
# ===========================================
*.log
logs/
backend/logs/

# ===========================================
# Docker
# ===========================================
docker-compose.override.yml

# ===========================================
# IDE Files
# ===========================================
.vscode/
.idea/
*.swp
*.swo

# ===========================================
# OS Files
# ===========================================
.DS_Store
._*
Thumbs.db
Desktop.ini

# ===========================================
# Temporary Files
# ===========================================
*.tmp
*.temp
temp/
tmp/

# ===========================================
# Cache
# ===========================================
.cache/
.eslintcache