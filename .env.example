# ===========================================
# DDF-ASTGCN Environment Configuration Example
# Copy this file to .env and fill in your actual values
# ===========================================

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://ddf_user:ddf_password@localhost:5432/ddf_db

# Individual Database Connection Parameters (for direct connections)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ddf_db
DB_USER=ddf_user
DB_PASSWORD=ddf_password

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ===========================================
# AI/ML Model Configuration
# ===========================================
# TorchServe Configuration
TORCHSERVE_URL=http://localhost:8080
TORCHSERVE_MODEL_NAME=mstgcn
TORCHSERVE_TIMEOUT=60

# Watson AI Configuration (for RAG Service)
WATSON_API_KEY=your_watson_api_key_here
WATSON_URL=https://us-south.ml.cloud.ibm.com
WATSON_PROJECT_ID=your_watson_project_id_here
WATSON_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# Model Path Configuration
MODEL_BASE_PATH=/app/ddf_model
ACTIVE_MODEL_VERSION=ddf_v1

# Model Architecture Parameters
NUM_OF_VERTICES=957
IN_CHANNELS=4
LEN_INPUT_HOUR=6
LEN_INPUT_DAY=24
LEN_INPUT_WEEK=24
NUM_FOR_PREDICT=24
K_ORDER=3

# Data Normalization Parameters
DATA_MEAN=0.1110
DATA_STD=1.1544

# ===========================================
# Seoul Traffic API Configuration
# ===========================================
# Seoul Traffic API Keys
SEOUL_TRAFFIC_API_KEY=your_api_key_here
API1_STATION_RIDERSHIP_KEY=your_api_key_here
API2_SECTION_RIDERSHIP_KEY=your_api_key_here
API3_EMD_OD_KEY=your_api_key_here
API4_SECTION_SPEED_KEY=your_api_key_here
# API Endpoints
API1_ENDPOINT=TaimsTpssStaRouteInfoH/1.0
API2_ENDPOINT=TaimsTpssA18RouteSection/1.0
API3_ENDPOINT=TaimsTpssEmdOdTc/1.0
API4_ENDPOINT=TaimsTpssRouteSectionSpeedH/1.0

# API Server Settings
SEOUL_API_BASE_URL=https://t-data.seoul.go.kr/apig/apiman-gateway/tapi
API_TIMEOUT=30
API_MAX_RETRIES=3

# DRT Analysis Settings
DRT_ANALYSIS_DATE=20250701
DRT_ANALYSIS_HOUR=13
DRT_TARGET_REGION=강남구
DRT_PILOT_VEHICLES=15
DRT_SERVICE_RADIUS=500

# ===========================================
# API Configuration
# ===========================================
# FastAPI Settings
PROJECT_NAME="DRT Demand Prediction API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000,http://frontend:3000"

# Performance Settings
MAX_BATCH_SIZE=100

# ===========================================
# Frontend Configuration
# ===========================================
REACT_APP_API_URL=http://localhost:8000
REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here

# ===========================================
# Cache Configuration
# ===========================================
# Redis Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# Timezone Configuration
# ===========================================
TZ=Asia/Seoul

# ===========================================
# Development Settings
# ===========================================
# Node Environment
NODE_ENV=development

# Debug Settings
DEBUG=true

# ===========================================
# How to get API Keys:
# ===========================================
# Seoul Open Data Portal: https://data.seoul.go.kr
# Watson AI: https://cloud.ibm.com/catalog/services/watson-machine-learning
# Mapbox: https://www.mapbox.com/