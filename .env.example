# Application settings
PROJECT_NAME=DDF-MSTGCN System
DEBUG=false
HOST=0.0.0.0
PORT=8001
SECRET_KEY=your-secret-key-change-in-production

# CORS settings
ALLOWED_HOSTS=*

# Watson AI settings
WATSON_API_KEY=your_watson_api_key
WATSON_URL=https://us-south.ml.cloud.ibm.com
WATSON_PROJECT_ID=your_watson_project_id
WATSON_MODEL_ID=ibm/granite-3-8b-instruct

# Database settings
DATABASE_URL=postgresql://ddf_user:ddf_password@postgres:5432/ddf_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis settings
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL=3600

# Vector store settings
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma
CHROMA_URL=http://chromadb:8000
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# RAG settings
DEFAULT_CONFIDENCE_THRESHOLD=0.5
MAX_RESULTS=10
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_LENGTH=4000

# LangChain settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=

# Logging settings
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Seoul Traffic API
SEOUL_TRAFFIC_API_KEY=your_seoul_traffic_api_key